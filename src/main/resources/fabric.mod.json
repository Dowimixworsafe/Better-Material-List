{
	"schemaVersion": 1,
	"id": "bettermateriallist",
	"version": "${version}",
	"name": "BML — Better Material List",
	"description": "A Litematica add-on that supercharges the material list: per-item checkboxes, tracked-chest 'stored' counts with in-world highlighting and content preview, a party system that syncs progress between players, a targeted-items HUD, and quick filtering.",
	"authors": [
		"Dowimixworsafe"
	],
	"contact": {
		"homepage": "https://github.com/Dowimixworsafe/Better-Material-List",
		"sources": "https://github.com/Dowimixworsafe/Better-Material-List",
		"issues": "https://github.com/Dowimixworsafe/Better-Material-List/issues"
	},
	"license": "ARR",
	"icon": "assets/bettermateriallist/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.example.ExampleMod"
		],
		"client": [
			"com.example.ExampleModClient"
		]
	},
	"mixins": [
		"modid.mixins.json",
		{
			"config": "modid.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*",
		"malilib": "*",
		"litematica": "*"
	}
}
